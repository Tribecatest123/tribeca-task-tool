{
  "name": "Tribeca Outbound (Calendar + Gmail)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "tribeca-task-outbound",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "11111111-1111-1111-1111-111111111111",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-160, 300],
      "webhookId": "tribeca-task-outbound"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-cal",
              "leftValue": "={{ $json.body.task_type }}",
              "rightValue": "calendar_event",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        },
        "options": {}
      },
      "id": "22222222-2222-2222-2222-222222222222",
      "name": "Is calendar_event?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [80, 300]
    },
    {
      "parameters": {
        "calendar": {
          "__rl": true,
          "value": "primary",
          "mode": "list",
          "cachedResultName": "primary"
        },
        "start": "={{ $json.body.datetime_start }}",
        "end": "={{ $json.body.datetime_end }}",
        "additionalFields": {
          "summary": "={{ $json.body.title }}",
          "description": "={{ $json.body.notes }}",
          "attendees": ["={{ $json.body.assignee_email }}"],
          "sendUpdates": "all"
        }
      },
      "id": "33333333-3333-3333-3333-333333333333",
      "name": "Create Calendar Event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1,
      "position": [320, 180],
      "notesInFlow": true,
      "notes": "Re-attach Google Calendar OAuth credential after import. Select your calendar in the Calendar field."
    },
    {
      "parameters": {
        "sendTo": "={{ $node[\"Webhook\"].json.body.assignee_email }}",
        "subject": "=[Tribeca Task #{{ $node[\"Webhook\"].json.body.task_id }}] {{ $node[\"Webhook\"].json.body.title }}",
        "emailType": "html",
        "message": "=<p>Hi <b>{{ $node[\"Webhook\"].json.body.assignee_name }}</b>,</p>\n<p>You have a new scheduled event:</p>\n<table cellpadding=\"6\" style=\"border-collapse:collapse;font-family:Arial,Helvetica,sans-serif;font-size:14px\">\n<tr><td style=\"font-weight:bold;vertical-align:top\">Event</td><td>{{ $node[\"Webhook\"].json.body.title }}</td></tr>\n<tr><td style=\"font-weight:bold;vertical-align:top\">When</td><td>{{ DateTime.fromISO($node[\"Webhook\"].json.body.datetime_start).setZone('Asia/Kolkata').toFormat('cccc, dd LLL yyyy, h:mm a') }} IST</td></tr>\n<tr><td style=\"font-weight:bold;vertical-align:top\">Priority</td><td>{{ $node[\"Webhook\"].json.body.priority.toUpperCase() }}</td></tr>\n<tr><td style=\"font-weight:bold;vertical-align:top\">Notes</td><td>{{ $node[\"Webhook\"].json.body.notes }}</td></tr>\n</table>\n<p>Reply to this email with any update — your reply will be recorded against this task.</p>\n<p style=\"color:#888888;font-size:12px\">This task was created with the Tribeca Task Tool.</p>",
        "options": { "appendAttribution": false }
      },
      "id": "44444444-4444-4444-4444-444444444444",
      "name": "Send Email (Calendar)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [560, 180],
      "notesInFlow": true,
      "notes": "Re-attach Gmail OAuth credential after import. This SENDS the email (not a draft)."
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ task_id: $node[\"Webhook\"].json.body.task_id, status: \"notified\", calendar_event_link: $node[\"Create Calendar Event\"].json.htmlLink }) }}",
        "options": {}
      },
      "id": "55555555-5555-5555-5555-555555555555",
      "name": "Respond (Calendar)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [800, 180]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.body.assignee_email }}",
        "subject": "=[Tribeca Task #{{ $json.body.task_id }}] {{ $json.body.title }}",
        "emailType": "html",
        "message": "=<p>Hi <b>{{ $json.body.assignee_name }}</b>,</p>\n<p>This is a reminder:</p>\n<table cellpadding=\"6\" style=\"border-collapse:collapse;font-family:Arial,Helvetica,sans-serif;font-size:14px\">\n<tr><td style=\"font-weight:bold;vertical-align:top\">Task</td><td>{{ $json.body.title }}</td></tr>\n<tr><td style=\"font-weight:bold;vertical-align:top\">Due</td><td>{{ DateTime.fromISO($json.body.datetime_start).setZone('Asia/Kolkata').toFormat('cccc, dd LLL yyyy, h:mm a') }} IST</td></tr>\n<tr><td style=\"font-weight:bold;vertical-align:top\">Priority</td><td>{{ $json.body.priority.toUpperCase() }}</td></tr>\n<tr><td style=\"font-weight:bold;vertical-align:top\">Notes</td><td>{{ $json.body.notes }}</td></tr>\n</table>\n<p>Reply to this email with any update — your reply will be recorded against this task.</p>\n<p style=\"color:#888888;font-size:12px\">This task was created with the Tribeca Task Tool.</p>",
        "options": { "appendAttribution": false }
      },
      "id": "66666666-6666-6666-6666-666666666666",
      "name": "Send Email (Reminder)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [320, 420],
      "notesInFlow": true,
      "notes": "Re-attach Gmail OAuth credential after import. This SENDS the email (not a draft)."
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ task_id: $node[\"Webhook\"].json.body.task_id, status: \"notified\", calendar_event_link: null }) }}",
        "options": {}
      },
      "id": "77777777-7777-7777-7777-777777777777",
      "name": "Respond (Reminder)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [560, 420]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Is calendar_event?", "type": "main", "index": 0 }]]
    },
    "Is calendar_event?": {
      "main": [
        [{ "node": "Create Calendar Event", "type": "main", "index": 0 }],
        [{ "node": "Send Email (Reminder)", "type": "main", "index": 0 }]
      ]
    },
    "Create Calendar Event": {
      "main": [[{ "node": "Send Email (Calendar)", "type": "main", "index": 0 }]]
    },
    "Send Email (Calendar)": {
      "main": [[{ "node": "Respond (Calendar)", "type": "main", "index": 0 }]]
    },
    "Send Email (Reminder)": {
      "main": [[{ "node": "Respond (Reminder)", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "pinData": {}
}
