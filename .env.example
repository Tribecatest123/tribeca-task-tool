# These are NOT committed and NOT read from a file by the deployed app.
# They are set as Supabase Edge Function SECRETS (Dashboard > Project Settings >
# Edge Functions > Secrets, or `supabase secrets set KEY=value`).
#
# The app code never contains these values.

# Used by the `parse` function to call OpenAI structured outputs.
OPENAI_API_KEY=sk-...

# Used by the `approve` function. This is the PRODUCTION webhook URL of the
# n8n outbound workflow. Copy it from n8n after you import + activate that workflow.
N8N_OUTBOUND_WEBHOOK_URL=https://YOUR-N8N-HOST/webhook/tribeca-task-outbound

# Note: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically
# into every Edge Function by Supabase. You do NOT set these yourself.
